{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pybegin-api",
  "main": "src/worker.py",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["python_workers"],
  "routes": [
    { "pattern": "pybegin.its-mrinank.com", "custom_domain": true }
  ],
  "observability": { "enabled": true }
}
